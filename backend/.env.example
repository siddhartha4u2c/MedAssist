FLASK_APP=wsgi.py
FLASK_ENV=development
# Windows + Next proxy: avoid `flask run` reloader (two LISTENING PIDs on :5001 → HTML 404). Prefer:
#   cd backend && .venv\Scripts\python wsgi.py
# or: flask --app wsgi:app run --host 127.0.0.1 --port 5001 --no-reload
SECRET_KEY=change-me
JWT_SECRET_KEY=
JWT_ACCESS_HOURS=24

# SQLite by default; set DATABASE_URL for PostgreSQL
# DATABASE_URL=postgresql://user:pass@localhost:5432/medassist

# Public URL of the Next.js app (activation & password-reset links)
FRONTEND_PUBLIC_URL=http://localhost:3000

# --- Real email (Gmail example) ---
# DEV_SKIP_EMAIL=true: OTP and other mail only print in the Flask terminal ([DEV_SKIP_EMAIL]).
DEV_SKIP_EMAIL=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
# For Gmail, SMTP_USER must be the same Google account as SMTP_FROM_EMAIL (use an App Password).
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=your.email@gmail.com

# --- SMS (Twilio) — lead capture OTP via mobile ---
# DEV_SKIP_SMS=true: OTP is printed in the Flask terminal ([DEV_SKIP_SMS]), not sent.
DEV_SKIP_SMS=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 sender, e.g. +15551234567 (use TWILIO_FROM_NUMBER if you prefer that name)
TWILIO_PHONE_NUMBER=
# When the user enters exactly 10 digits, prepend this country code (default India 91).
SMS_DEFAULT_COUNTRY_CODE=91

# EURI (OpenAI-compatible SDK — use EURI_API_KEY, not OPENAI_API_KEY)
EURI_API_KEY=
EURI_BASE_URL=https://api.euron.one/api/v1/euri
LLM_MODEL_PRIMARY=gpt-4o
LLM_MODEL_FAST=gpt-4o-mini
LLM_EMBEDDING_MODEL=text-embedding-3-large

# DR7 medical chat (used by Symptom Tracker + Patient AI Assistant when DR7_API_KEY is set)
DR7_API_KEY=
DR7_API_URL=https://dr7.ai/api/v1/medical/chat/completions
DR7_MODEL=medgemma-27b-it

# --- Pinecone RAG (Symptom Analyst medical knowledge) ---
# PINECONE_INDEX_NAME defaults to quickstart; vectors must match LLM_EMBEDDING_MODEL dimensions.
PINECONE_API_KEY=
PINECONE_INDEX_NAME=quickstart
# Optional: namespace within the index; leave empty for default.
# PINECONE_NAMESPACE=
# If your index was created with a fixed dimension (e.g. 1536), set it to match embeddings:
# PINECONE_EMBEDDING_DIMENSIONS=1536
# RAG_TOP_K=5

# --- Daily.co (telemedicine video) — recommended ---
# Put secrets in this file (backend/.env). An optional second file backend/backend.env is also loaded if it exists.
# Dashboard → Developers → API key. MedAssist creates a room per telemedicine booking and stores the join URL.
# DAILY_API_KEY=your_key_here
# (Usually no quotes. If you wrap the value in plain ASCII " or ', MedAssist strips one matching pair so Daily still gets the raw key.)
# Optional (default https://api.daily.co/v1):
# DAILY_API_BASE_URL=https://api.daily.co/v1
# Seconds after the scheduled visit end before Daily auto-deletes the room (default 3600):
# DAILY_ROOM_EXP_BUFFER_SEC=3600
# If Daily rejects room creation, try omitting exp: DAILY_SKIP_ROOM_EXP=true
# Call recording (Daily room property enable_recording). Requires a Daily plan that supports it; use consent in UI.
# Values: cloud | cloud-audio-only | local | raw-tracks — or true/1/on for cloud. Empty = off.
# DAILY_ENABLE_RECORDING=cloud
# Optional: merge extra fields into Daily "create room" JSON (must be valid JSON object):
# DAILY_CREATE_ROOM_JSON={"enable_screenshare":true}

# --- Generic video provider (only if Daily.co is not used) ---
# VIDEOCO_API_BASE_URL=https://api.your-provider.com
# VIDEOCO_API_KEY=
# VIDEOCO_CREATE_ROOM_PATH=/rooms
# VIDEOCO_CREATE_BODY_JSON={"privacy":"private"}
# VIDEOCO_API_KEY_HEADER_NAME=X-Api-Key
# VIDEOCO_REQUEST_TIMEOUT_SEC=20
