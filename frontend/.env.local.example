# Recommended: leave NEXT_PUBLIC_API_URL unset so the browser uses same-origin /api/v1/* → Flask.
# If you set NEXT_PUBLIC_API_URL, it MUST end with /api/v1 (e.g. http://127.0.0.1:5001/api/v1).
# A bare origin without /api/v1 makes requests hit /auth/... instead of /api/v1/auth/... → NOT_FOUND.
# Never set this to your EURI / OpenAI URL — that also returns NOT_FOUND for MedAssist routes.

# MedAssist Flask (match `flask run --port`; default in code is 5001).
BACKEND_URL=http://127.0.0.1:5001

# Leave NEXT_PUBLIC_API_URL unset so the browser uses same-origin /api/v1 (avoids CORS "Failed to fetch").
# Only set if you intentionally call Flask from the browser; use the same host as the app (e.g. localhost) and fix CORS.
# NEXT_PUBLIC_API_URL=http://127.0.0.1:5001/api/v1
